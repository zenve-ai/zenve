# Application

dev:
    API_RELOAD=true uv run --package zenve-api api-start

start:
    uv run --package zenve-api api-start

# Package management

install:
    uv sync

add-to-api package:
    uv add --package zenve-api {{package}}

add-to-pkg pkg package:
    uv add --package {{pkg}} {{package}}

update:
    uv lock --upgrade
    uv sync

# Docker

docker-build:
    docker build -f apps/api/Dockerfile -t zenve-api:latest .

docker-up:
    docker compose up -d

docker-down:
    docker compose down

docker-logs:
    docker compose logs -f

# Testing

test path="packages/adapters/tests":
    uv run pytest {{path}} -v

test-file file:
    uv run pytest {{file}} -v

# Code quality

format:
    uv run ruff format .

lint path=".":
    uv run ruff check {{path}}

lint-fix path=".":
    uv run ruff check --fix {{path}}

typecheck path=".":
    uv run pyright {{path}}
