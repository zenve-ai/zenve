dev:
    API_RELOAD=true uv run --package zenve-api api-start

# Database migrations (Alembic)

migrate:
    uv run alembic upgrade head

migrate-down:
    uv run alembic downgrade -1

migrate-gen msg="migration":
    uv run alembic revision --autogenerate -m "{{msg}}"

cli *args:
    uv run --package zenve-cli zenve {{args}}

cli-bump bump="patch":
    #!/usr/bin/env python3
    import subprocess, re
    from pathlib import Path

    result = subprocess.run(
        ["git", "tag", "--sort=-v:refname", "--list", "v*"],
        capture_output=True, text=True, cwd=".."
    )
    tags = [t for t in result.stdout.strip().split("\n") if re.match(r"v\d+\.\d+\.\d+$", t)]
    if not tags:
        print("No version tags found"); exit(1)

    major, minor, patch = map(int, tags[0].lstrip("v").split("."))
    bump = "{{bump}}"
    if bump == "major":   major += 1; minor = 0; patch = 0
    elif bump == "minor": minor += 1; patch = 0
    else:                 patch += 1

    new_version = f"{major}.{minor}.{patch}"
    print(f"Last tag: {tags[0]}  →  new version: v{new_version}")

    pyproject = Path("apps/cli/pyproject.toml")
    pyproject.write_text(re.sub(r'(?<=version = ")[^"]+', new_version, pyproject.read_text()))

    init = Path("apps/cli/src/zenve_cli/__init__.py")
    init.write_text(re.sub(r'(?<=__version__ = ")[^"]+', new_version, init.read_text()))

    print(f"Updated pyproject.toml and __init__.py to {new_version}")

cli-build:
    uv sync --all-packages
    uv run --with pyinstaller pyinstaller apps/cli/zenve.spec --distpath apps/cli/dist --workpath /tmp/pyinstaller_build --noconfirm
    @echo "Binary built: apps/cli/dist/zenve"

cli-install:
    uv tool install --editable apps/cli \
        --with 'zenve-config @ packages/config' \
        --with 'zenve-db @ packages/db' \
        --with 'zenve-models @ packages/models' \
        --with 'zenve-utils @ packages/utils' \
        --with 'zenve-services @ packages/services' \
        --with 'zenve-adapters @ packages/adapters'

cli-link:
    #!/bin/sh
    TARGET="$HOME/.local/bin/zenve"
    printf '#!/bin/sh\nexec %s "$@"\n' "$(pwd)/.venv/bin/zenve" > "$TARGET"
    chmod +x "$TARGET"
    echo "Linked: zenve → $TARGET"

start:
    uv run --package zenve-api api-start

# Package management

install:
    uv sync

add-to-api package:
    uv add --package zenve-api {{package}}

add-to-pkg pkg package:
    uv add --package {{pkg}} {{package}}

update:
    uv lock --upgrade
    uv sync

# Docker

docker-build:
    docker build -f apps/api/Dockerfile -t zenve-api:latest .

docker-up:
    docker compose up -d

docker-down:
    docker compose down

docker-logs:
    docker compose logs -f

# Testing

test path="packages":
    uv run pytest {{path}} -v

test-file file:
    uv run pytest {{file}} -v

# Code quality

format:
    uv run ruff format .

lint path=".":
    uv run ruff check {{path}}

lint-fix path=".":
    uv run ruff check --fix {{path}}

typecheck path=".":
    uv run pyright {{path}}
